{
    "Knot": {
        "prefix": "knot",
        "body": [
            "=== ${1:knot_name} ===",
            "$0",
            "-"
        ],
        "description": "Define a new knot"
    },
    "Stitch": {
        "prefix": "stitch",
        "body": [
            "= ${1:stitch_name}",
            "$0"
        ],
        "description": "Define a new stitch"
    },
    "Function": {
        "prefix": "func",
        "body": [
            "=== function ${1:name}(${2:params}) ===",
            "\t~ return $0"
        ],
        "description": "Define an Ink function"
    },
    "VAR": {
        "prefix": "var",
        "body": "VAR ${1:name} = ${2:value}",
        "description": "Declare a story variable"
    },
    "CONST": {
        "prefix": "const",
        "body": "CONST ${1:name} = ${2:value}",
        "description": "Declare a constant"
    },
    "LIST": {
        "prefix": "list",
        "body": "LIST ${1:name} = ${2:item1}, ${3:item2}",
        "description": "Declare a list type"
    },
    "INCLUDE": {
        "prefix": "include",
        "body": "INCLUDE ${1:file}.ink",
        "description": "Include another Ink file"
    },
    "Choice": {
        "prefix": "choice",
        "body": "* [${1:text}]$0",
        "description": "A basic choice"
    },
    "Named choice": {
        "prefix": "nchoice",
        "body": "* (${1:label}) [${2:display text}]$0",
        "description": "A named choice with a label"
    },
    "Sticky choice": {
        "prefix": "schoice",
        "body": "+ [${1:text}]$0",
        "description": "A sticky choice (repeats)"
    },
    "Conditional": {
        "prefix": "cond",
        "body": "{${1:condition}: ${2:if true}|${3:if false}}",
        "description": "Inline conditional: {condition: true | false}"
    },
    "If / else block": {
        "prefix": "ifcond",
        "body": [
            "{ ${1:condition}:",
            "\t${2:// if true}",
            "- else:",
            "\t${3:// if false}",
            "}"
        ],
        "description": "Block-level if/else conditional"
    },
    "If / else if / else block": {
        "prefix": "ifelseif",
        "body": [
            "{ ${1:condition}:",
            "\t${2:// if true}",
            "- else if ${3:other_condition}:",
            "\t${4:// else if true}",
            "- else:",
            "\t${5:// if false}",
            "}"
        ],
        "description": "Block-level if/else if/else conditional"
    },
    "Divert": {
        "prefix": "divert",
        "body": "-> ${1:target}",
        "description": "Divert to a knot or stitch"
    },
    "Divert END": {
        "prefix": "end",
        "body": "-> END",
        "description": "Divert to END (finish story)"
    },
    "Divert DONE": {
        "prefix": "done",
        "body": "-> DONE",
        "description": "Divert to DONE (end of choices)"
    },
    "Tunnel": {
        "prefix": "tunnel",
        "body": "-> ${1:target} ->",
        "description": "Tunnel: divert and return"
    },
    "Thread": {
        "prefix": "thread",
        "body": "<- ${1:target}",
        "description": "Thread: weave in content from another knot"
    },
    "Tilde assignment": {
        "prefix": "tilde",
        "body": "~ ${1:variable} = ${2:value}",
        "description": "Assign a value to a variable"
    },
    "Temp variable": {
        "prefix": "temp",
        "body": "~ temp ${1:name} = ${2:value}",
        "description": "Declare a temporary variable"
    },
    "Tag": {
        "prefix": "tag",
        "body": "# ${1:tag}",
        "description": "Add a tag to a line"
    },
    "Gather with label": {
        "prefix": "glabel",
        "body": "- (${1:label_name})$0",
        "description": "A gather point with a label"
    },
    "TODO comment": {
        "prefix": "todo",
        "body": "TODO: ${1:description}",
        "description": "Ink TODO marker"
    }
}
